# ── Servidor Backend ──────────────────────────────────────────────────────────
PORT=3001
PUBLIC_BASE_URL=https://api-call.v4companyamaral.com
WS_PUBLIC_URL=wss://api-call.v4companyamaral.com/media
NODE_ENV=production

# ── Banco de Dados (PostgreSQL) ───────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=callcenter
DB_USER=postgres
DB_PASSWORD=troque_para_senha_forte

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+5511XXXXXXXXX

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash-live-001
GEMINI_VOICE=Kore

# ── Empresa ───────────────────────────────────────────────────────────────────
EMPRESA_NOME=V4 Company

# ── Integrações ───────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=

# ── NextAuth (Frontend) ───────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=troque_para_secret_forte
NEXTAUTH_URL=https://call.v4companyamaral.com

# Crie em: https://console.cloud.google.com → APIs → Credenciais → OAuth 2.0
# URI de redirecionamento: https://call.v4companyamaral.com/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxx

# DATABASE_URL usado pelo NextAuth (mesmo banco, formato URL)
DATABASE_URL=postgresql://postgres:troque_para_senha_forte@postgres:5432/callcenter
